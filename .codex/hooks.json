{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/continuity.py\" session-start",
            "timeout": 10,
            "statusMessage": "Loading continuity note"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/prompt_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking prompt for repo safety context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/post_edit_review.py\"",
            "timeout": 15,
            "statusMessage": "Reviewing edit hygiene"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/continuity.py\" pre-compact",
            "timeout": 20,
            "statusMessage": "Saving continuity before compaction"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/continuity.py\" post-compact",
            "timeout": 20,
            "statusMessage": "Updating continuity after compaction"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_summary.py\"",
            "timeout": 20,
            "statusMessage": "Summarizing repo state"
          }
        ]
      }
    ]
  }
}
