#!/usr/bin/env sh
set -eu

msg_file="$1"
msg="$(tr '[:upper:]' '[:lower:]' < "$msg_file")"

case "$msg" in
  *"secure cipher"*|*"better encryption"*|*"production crypto"*|*"unbreakable"*)
    echo "commit-msg: avoid broad crypto claims in commit messages." >&2
    echo "Use evidence-neutral wording such as: add baseline tests, document experiment, or update benchmark." >&2
    exit 1
    ;;
esac
